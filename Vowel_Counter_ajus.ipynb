      "source": [
        "\n",
        "def count_vowels(text):\n",
        "    vowels = \"aeiouAEIOU\"\n",
        "    count = 0\n",
        "\n",
        "    for character in text:\n",
        "        if character in vowels:\n",
        "            count += 1\n",
        "\n",
        "    return count\n",
        "\n",
        "\n",
        "text = input(\"Enter a string: \")\n",
        "result = count_vowels(text)\n",
        "\n",
        "print(\"Number of vowels:\", result)"
      ]
    }
  ]
}
          "text": [
            "Enter a number: 10\n",
            "Sum of even numbers: 30\n",
            "( 2 + 4 + 6 + 8 + 10 )\n"
          ]
        }
      ],
      "source": [
        "\n",
        "number = int(input(\"Enter a number: \"))\n",
        "\n",
        "even_numbers = []\n",
        "total = 0\n",
        "\n",
        "for value in range(2, number + 1, 2):\n",
        "    even_numbers.append(value)\n",
        "    total += value\n",
        "\n",
        "print(\"Sum of even numbers:\", total)\n",
        "\n",
        "if even_numbers:\n",
        "    print(\"(\", \" + \".join(map(str, even_numbers)), \")\")"
      ]
    }
  ]
